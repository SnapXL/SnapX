<UserControl
  d:DesignHeight="700"
  d:DesignWidth="450"
  mc:Ignorable="d"
  x:Class="SnapX.Avalonia.Views.MainView"
  x:DataType="viewModels:MainViewModel"
  xmlns="https://github.com/avaloniaui"
  xmlns:controls="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
  xmlns:converters="clr-namespace:SnapX.Avalonia.Converters"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:models="clr-namespace:SnapX.Avalonia.Models"
  xmlns:utils="clr-namespace:SnapX.Core.Utils;assembly=SnapX.Core"
  xmlns:viewModels="clr-namespace:SnapX.Avalonia.ViewModels"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Design.DataContext>
    <viewModels:MainViewModel />
  </Design.DataContext>
  <Grid RowDefinitions="Auto, *">
    <SplitView
      Background="{DynamicResource SolidBackgroundFillColorBase}"
      CompactPaneLength="46"
      DisplayMode="CompactInline"
      Grid.Row="1"
      IsPaneOpen="{Binding IsPaneOpen}"
      OpenPaneLength="170">

      <SplitView.Pane>
        <controls:CommandBar
          DefaultLabelPosition="Right"
          IsDynamicOverflowEnabled="True"
          IsOpen="{Binding IsPaneOpen}"
          UseLayoutRounding="True">
          <controls:CommandBar.PrimaryCommands>
            <controls:CommandBarButton Command="{Binding TriggerPaneCommand}" IconSource="GlobalNavigationButton" />

            <controls:CommandBarElementContainer>

              <ListBox ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedListItem}">
                <ListBox.ItemTemplate>
                  <DataTemplate DataType="{x:Type models:ListItemTemplate}">
                    <StackPanel Orientation="Horizontal" Spacing="17">
                      <PathIcon Data="{Binding IconKey, Converter={x:Static converters:TypeConverters.IconConverter}}"
                                Width="16" />
                      <TextBlock
                        Text="{Binding Label}"
                        TextTrimming="WordEllipsis"
                        TextWrapping="Wrap" />
                    </StackPanel>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </controls:CommandBarElementContainer>
          </controls:CommandBar.PrimaryCommands>
          <controls:CommandBar.SecondaryCommands>
            <controls:CommandBarElementContainer>
              <WrapPanel Orientation="Horizontal">
                <SplitButton x:Name="CaptureSplitButton">
                  <WrapPanel Orientation="Horizontal">
                    <controls:SymbolIcon Symbol="Camera" FontSize="20" />
                    <Label Content="Region" Name="RegionCaptureLabel" />
                  </WrapPanel>
                  <SplitButton.Flyout>
                    <controls:FAMenuFlyout>
                      <controls:ToggleMenuFlyoutItem
                        Text="{x:Static utils:Lang.UI_Dropdown_Region}"
                        IconSource="Camera" />
                      <controls:ToggleMenuFlyoutItem
                        Text="{x:Static utils:Lang.UI_Dropdown_RegionLight}" />
                      <controls:ToggleMenuFlyoutItem
                        Text="{x:Static utils:Lang.UI_Dropdown_RegionTransparent}" />
                      <controls:ToggleMenuFlyoutItem
                        Text="{x:Static utils:Lang.UI_Dropdown_Window}" />
                      <controls:ToggleMenuFlyoutItem
                        Text="{x:Static utils:Lang.UI_Dropdown_Monitor}" />


                    </controls:FAMenuFlyout>
                  </SplitButton.Flyout>
                </SplitButton>
              </WrapPanel>
            </controls:CommandBarElementContainer>
            <controls:CommandBarButton
              Command="{Binding OpenAboutWindowCommand}"
              IconSource="Favorite"
              Label="{x:Static utils:Lang.AboutSnapX}" />
          </controls:CommandBar.SecondaryCommands>
        </controls:CommandBar>
      </SplitView.Pane>


      <Border>
        <TransitioningContentControl Content="{Binding CurrentPage}" />
      </Border>
    </SplitView>

  </Grid>
</UserControl>
