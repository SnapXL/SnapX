<UserControl xmlns="https://github.com/avaloniaui"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
              xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
              xmlns:viewModels="clr-namespace:SnapX.Avalonia.ViewModels"
              xmlns:converters="clr-namespace:SnapX.Avalonia.Converters"
              xmlns:models="clr-namespace:SnapX.Avalonia.Models"
              mc:Ignorable="d" d:DesignWidth="450" d:DesignHeight="700"
              x:Class="SnapX.Avalonia.Views.MainView"
              x:DataType="viewModels:MainViewModel">
    <Design.DataContext>
        <viewModels:MainViewModel />
    </Design.DataContext>
        <Grid RowDefinitions="Auto, *">
        <SplitView
            IsPaneOpen="{Binding IsPaneOpen}"
            CompactPaneLength="46"
            DisplayMode="CompactInline"
            OpenPaneLength="200"
            Background="#1e1e1e"
            PaneBackground="#1e1e1e"
            Grid.Row ="1"
            >
            <SplitView.Pane>
                <StackPanel
                    Orientation="Vertical"
                    Spacing="5"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Top"
                    >
                    <Button
                        HorizontalAlignment="Left"
                        Width="32"
                        Height="32"
                        Margin="0 10"
                        Command="{Binding TriggerPaneCommand}"
                        >
                        <PathIcon Height="11" Data="{StaticResource LineHorizontal3Regular}"/>
                    </Button>
                    <ListBox
                        Margin="5 0"
                        Padding="0"
                        ItemsSource="{Binding Items}"
                        SelectedItem="{Binding SelectedListItem}"
                        >
                        <ListBox.Styles>
                            <Style Selector="ListBoxItem">
                                <Setter Property="Padding" Value="12 8"/>
                            </Style>
                        </ListBox.Styles>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:ListItemTemplate}">
                                <StackPanel Spacing="17" Orientation="Horizontal">
                                    <PathIcon Data="{Binding IconKey, Converter={x:Static converters:TypeConverters.IconConverter}}"
                                              Width="14" />
                                    <TextBlock Text="{Binding Label}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </SplitView.Pane>

            <SplitView.Content>
                <Border Background="#2d2d2d">
                    <Grid>
                        <TransitioningContentControl Content="{Binding CurrentPage}" />
                        <!-- <Button Click="ClickAboutButton"> -->
                        <!--     <Button.Content> -->
                        <!--         <StackPanel> -->
                        <!--             <StaticResource ResourceKey="SettingsIcon"/> -->
                        <!--             <TextBlock Text="About SnapX"/> -->
                        <!--         </StackPanel> -->
                        <!--     </Button.Content> -->
                        <!-- -->
                        <!-- </Button> -->
                    </Grid>
                </Border>
            </SplitView.Content>
        </SplitView>
    </Grid>
</UserControl>
