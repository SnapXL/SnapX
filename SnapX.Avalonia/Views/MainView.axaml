<UserControl
    Initialized="MainView_OnInit"
    d:DesignHeight="700"
    d:DesignWidth="450"
    mc:Ignorable="d"
    x:Class="SnapX.Avalonia.Views.MainView"
    x:DataType="viewModels:MainViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:controls="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
    xmlns:core="clr-namespace:SnapX.Core;assembly=SnapX.Core"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fluent="clr-namespace:FluentIcons.Avalonia.Fluent;assembly=FluentIcons.Avalonia.Fluent"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:utils="clr-namespace:SnapX.Core.Utils;assembly=SnapX.Core"
    xmlns:viewModels="clr-namespace:SnapX.Avalonia.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Design.DataContext>
        <viewModels:MainViewModel />
    </Design.DataContext>
    <controls:NavigationView
        Background="{DynamicResource SolidBackgroundFillColorBase}"
        IsPaneOpen="{Binding IsPaneOpen}"
        IsSettingsVisible="False"
        OpenPaneLength="220"
        PaneDisplayMode="Left"
        PaneTitle="SnapX"
        UseLayoutRounding="True"
        Name="MainNavView">

        <controls:NavigationView.MenuItems>
            <controls:NavigationViewItem Content="Region" x:Name="CaptureSplitButton">
                <controls:NavigationViewItem.IconSource>
                    <fluent:FluentIconSource
                        Icon="Camera"
                        IconSize="Size32"
                        IconVariant="Regular" />
                </controls:NavigationViewItem.IconSource>

                <controls:NavigationViewItem.MenuItems>
                    <controls:NavigationViewItem Content="{x:Static utils:Lang.UI_Capture_Fullscreen}" IconSource="Camera" />
                    <controls:NavigationViewItem Content="{x:Static utils:Lang.UI_Dropdown_Window}" IconSource="Camera" />
                    <controls:NavigationViewItem Content="{x:Static utils:Lang.UI_Dropdown_Monitor}" IconSource="Camera" />
                    <controls:NavigationViewItem Content="{x:Static utils:Lang.UI_Dropdown_Region}" IconSource="Camera" />
                    <!-- <controls:NavigationViewItem Content="{x:Static utils:Lang.UI_Dropdown_RegionLight}" IconSource="Camera" />
                    <controls:NavigationViewItem Content="{x:Static utils:Lang.UI_Dropdown_RegionTransparent}" IconSource="Camera" /> -->
                    <!-- <controls:NavigationViewItem Content="{x:Static utils:Lang.UI_Dropdown_ScreenRecording}" IconSource="Camera" />
                    <controls:NavigationViewItem Content="{x:Static utils:Lang.UI_Dropdown_ScreenRecordingGIF}" IconSource="Camera" /> -->

                    <!--  Delay submenu  -->
                    <controls:NavigationViewItem Content="Delay" IconSource="Clock" Name="DelayMenuItem">
                        <controls:NavigationViewItem.MenuItems>

                            <controls:NavigationViewItem
                                Content="1 second"
                                Tag="1"
                                Tapped="DelayOption_Checked"
                                PointerPressed="DelayOption_Checked" />
                            <controls:NavigationViewItem
                                Content="5 seconds"
                                Tag="5"
                                Tapped="DelayOption_Checked" />
                            <controls:NavigationViewItem
                                Content="10 seconds"
                                Tag="10"
                                Tapped="DelayOption_Checked" />
                            <controls:NavigationViewItem
                                Content="30 seconds"
                                Tag="30"
                                Tapped="DelayOption_Checked" />
                        </controls:NavigationViewItem.MenuItems>
                    </controls:NavigationViewItem>
                </controls:NavigationViewItem.MenuItems>
            </controls:NavigationViewItem>

            <controls:NavigationViewItem Content="Tools">
                <controls:NavigationViewItem.IconSource>
                    <fluent:FluentIconSource
                        Icon="Toolbox"
                        IconSize="Size32"
                        IconVariant="Regular" />
                </controls:NavigationViewItem.IconSource>
                <controls:NavigationViewItem.MenuItems>
                    <controls:NavigationViewItem Content="QR Code" PointerPressed="ToolClicked">
                        <controls:NavigationViewItem.IconSource>
                            <fluent:FluentIconSource
                                Icon="QrCode"
                                IconSize="Size32"
                                IconVariant="Regular" />
                        </controls:NavigationViewItem.IconSource>
                    </controls:NavigationViewItem>
                </controls:NavigationViewItem.MenuItems>
            </controls:NavigationViewItem>

            <controls:NavigationViewItem
                Content="Screenshot Folder"
                PointerPressed="DynamicURL_OnPointerPressed"
                ToolTip.Tip="{x:Static core:SnapX.ScreenshotsParentFolder}">
                <controls:NavigationViewItem.IconSource>
                    <fluent:FluentIconSource
                        Icon="Folder"
                        IconSize="Size32"
                        IconVariant="Regular" />
                </controls:NavigationViewItem.IconSource>
            </controls:NavigationViewItem>
        </controls:NavigationView.MenuItems>
        <controls:NavigationView.FooterMenuItems>
            <controls:NavigationViewItem Content="About" PointerPressed="AboutItem_Pressed">
                <controls:NavigationViewItem.IconSource>
                    <fluent:FluentIconSource
                        Icon="InfoSparkle"
                        IconSize="Size32"
                        IconVariant="Regular" />
                </controls:NavigationViewItem.IconSource>
            </controls:NavigationViewItem>
            <controls:NavigationViewItem Content="Donate" PointerPressed="DonateButtonPressed">
                <controls:NavigationViewItem.IconSource>
                    <fluent:FluentIconSource
                        Icon="PersonHeart"
                        IconSize="Size32"
                        IconVariant="Regular" />
                </controls:NavigationViewItem.IconSource>
            </controls:NavigationViewItem>
            <controls:NavigationViewItem Content="Debug">
                <controls:NavigationViewItem.IconSource>
                    <fluent:FluentIconSource
                        Icon="BoxSearch"
                        IconSize="Size32"
                        IconVariant="Regular" />
                </controls:NavigationViewItem.IconSource>
                <controls:NavigationView.MenuItems>
                    <controls:NavigationViewItem
                        Content="Log"
                        IconSource="Repair"
                        PointerPressed="OpenDebugLog" />
                    <controls:NavigationViewItem Content="{x:Static utils:Lang.UI_Debug_TestImageUpload}" PointerPressed="DynamicDebugPressed">
                        <controls:NavigationViewItem.IconSource>
                            <fluent:FluentIconSource
                                Icon="ImageGlobe"
                                IconSize="Size32"
                                IconVariant="Regular" />
                        </controls:NavigationViewItem.IconSource>
                    </controls:NavigationViewItem>
                    <controls:NavigationViewItem Content="{x:Static utils:Lang.UI_Debug_TestTextUpload}" PointerPressed="DynamicDebugPressed">
                        <controls:NavigationViewItem.IconSource>
                            <fluent:FluentIconSource
                                Icon="ScanText"
                                IconSize="Size32"
                                IconVariant="Regular" />
                        </controls:NavigationViewItem.IconSource>

                    </controls:NavigationViewItem>
                    <controls:NavigationViewItem Content="{x:Static utils:Lang.UI_Debug_TestFileUpload}" PointerPressed="DynamicDebugPressed">
                        <controls:NavigationViewItem.IconSource>
                            <fluent:FluentIconSource
                                Icon="Document"
                                IconSize="Size32"
                                IconVariant="Regular" />
                        </controls:NavigationViewItem.IconSource>

                    </controls:NavigationViewItem>
                    <controls:NavigationViewItem Content="{x:Static utils:Lang.UI_Debug_TestURLShortener}" PointerPressed="DynamicDebugPressed">
                        <controls:NavigationViewItem.IconSource>
                            <fluent:FluentIconSource
                                Icon="WebAsset"
                                IconSize="Size32"
                                IconVariant="Regular" />
                        </controls:NavigationViewItem.IconSource>

                    </controls:NavigationViewItem>
                    <controls:NavigationViewItem Content="{x:Static utils:Lang.UI_Debug_TestURLSharing}" PointerPressed="DynamicDebugPressed">
                        <controls:NavigationViewItem.IconSource>
                            <fluent:FluentIconSource
                                Icon="Share"
                                IconSize="Size32"
                                IconVariant="Regular" />
                        </controls:NavigationViewItem.IconSource>

                    </controls:NavigationViewItem>
                </controls:NavigationView.MenuItems>
            </controls:NavigationViewItem>
            <controls:NavigationViewItem Content="Settings" PointerPressed="SettingsItem_Pressed">
                <controls:NavigationViewItem.IconSource>
                    <fluent:FluentIconSource
                        Icon="Settings"
                        IconSize="Size32"
                        IconVariant="Regular" />
                </controls:NavigationViewItem.IconSource>
            </controls:NavigationViewItem>
        </controls:NavigationView.FooterMenuItems>
        <controls:NavigationView.AutoCompleteBox>
            <!--
                See AutoSuggestBox documentation for
                more info about how to implement search.
            -->
            <AutoCompleteBox x:Name="NavViewSearchBox" />
        </controls:NavigationView.AutoCompleteBox>
        <Border>
            <TransitioningContentControl Content="{Binding CurrentPage}" />
        </Border>
    </controls:NavigationView>
</UserControl>
