<UserControl
    DetachedFromVisualTree="CustomUploaderView_Detached"
    Initialized="CustomUploaderView_Initialized"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:Class="SnapX.Avalonia.Views.Settings.Views.CustomUploaderView"
    x:DataType="viewModels:CustomUploaderVM"
    xmlns="https://github.com/avaloniaui"
    xmlns:avalonia="clr-namespace:FluentIcons.Avalonia.Fluent;assembly=FluentIcons.Avalonia.Fluent"
    xmlns:controls="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:upload="clr-namespace:SnapX.Core.Upload.Custom;assembly=SnapX.Core"
    xmlns:viewModels="clr-namespace:SnapX.Avalonia.ViewModels"
    xmlns:views="clr-namespace:SnapX.Avalonia.Views.Settings.Views"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Design.DataContext>
        <viewModels:CustomUploaderVM />
    </Design.DataContext>
    <UserControl.DataContext>
        <viewModels:CustomUploaderVM />
    </UserControl.DataContext>
    <SplitView
        DisplayMode="CompactInline"
        IsEnabled="{Binding IsUiEnabled}"
        IsPaneOpen="True">
        <!--  Sidebar  -->
        <SplitView.Pane>
            <DockPanel LastChildFill="True">
                <Border
                    Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                    BorderThickness="0,1,0,0"
                    DockPanel.Dock="Bottom"
                    Grid.Row="1"
                    Padding="12">
                    <StackPanel Spacing="15">
                        <StackPanel
                            Margin="0,5,0,0"
                            Orientation="Horizontal"
                            Spacing="6">
                            <TextBlock
                                FontSize="14"
                                FontWeight="Bold"
                                Text="Active Uploaders" />
                            <avalonia:FluentIcon
                                FontSize="14"
                                Icon="QuestionCircle"
                                Opacity="0.6">
                                <ToolTip.Tip>
                                    <TextBlock xml:space="preserve">These dropdowns are *ONLY* for custom uploaders. To configure the regular built in destinations check your sidebar.</TextBlock>
                                </ToolTip.Tip>
                            </avalonia:FluentIcon>
                        </StackPanel>

                        <StackPanel Spacing="12">

                            <StackPanel Spacing="4">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <avalonia:SymbolIcon FontSize="18" Symbol="Image" />

                                    <TextBlock
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Text="Image" />
                                </StackPanel>
                                <Grid ColumnDefinitions="*, Auto">
                                    <ComboBox
                                        DisplayMemberBinding="{Binding}"
                                        Grid.Column="0"
                                        HorizontalAlignment="Stretch"
                                        IsEnabled="{Binding !IsEmpty}"
                                        ItemsSource="{Binding ImageUploaders}"
                                        SelectedItem="{Binding SelectedImageUploader}" />
                                    <Button
                                        Command="{Binding TestUploaderCommand}"
                                        CommandParameter="{Binding SelectedImageUploader}"
                                        Content="Test"
                                        FontSize="11"
                                        Grid.Column="1"
                                        IsEnabled="{Binding !IsEmpty}"
                                        Margin="4,0,0,0"
                                        VerticalAlignment="Stretch" />
                                </Grid>
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <avalonia:SymbolIcon FontSize="18" Symbol="Document" />
                                    <TextBlock
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Text="File" />
                                </StackPanel>
                                <Grid ColumnDefinitions="*, Auto">
                                    <ComboBox
                                        DisplayMemberBinding="{Binding}"
                                        Grid.Column="0"
                                        HorizontalAlignment="Stretch"
                                        IsEnabled="{Binding !IsEmpty}"
                                        ItemsSource="{Binding FileUploaders}"
                                        SelectedItem="{Binding SelectedFileUploader}" />
                                    <Button
                                        Command="{Binding TestUploaderCommand}"
                                        CommandParameter="{Binding SelectedFileUploader}"
                                        Content="Test"
                                        FontSize="11"
                                        Grid.Column="1"
                                        IsEnabled="{Binding !IsEmpty}"
                                        Margin="4,0,0,0"
                                        VerticalAlignment="Stretch" />
                                </Grid>
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <avalonia:SymbolIcon FontSize="18" Symbol="TextWholeWord" />

                                    <TextBlock
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Text="Text" />
                                </StackPanel>
                                <Grid ColumnDefinitions="*, Auto">
                                    <ComboBox
                                        DisplayMemberBinding="{Binding}"
                                        Grid.Column="0"
                                        HorizontalAlignment="Stretch"
                                        IsEnabled="{Binding !IsEmpty}"
                                        ItemsSource="{Binding TextUploaders}"
                                        SelectedItem="{Binding SelectedTextUploader}" />
                                    <Button
                                        Command="{Binding TestUploaderCommand}"
                                        CommandParameter="{Binding SelectedTextUploader}"
                                        Content="Test"
                                        FontSize="11"
                                        Grid.Column="1"
                                        IsEnabled="{Binding !IsEmpty}"
                                        Margin="4,0,0,0"
                                        VerticalAlignment="Stretch" />
                                </Grid>
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <avalonia:SymbolIcon FontSize="18" Symbol="Link" />

                                    <TextBlock
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Text="Shortener" />
                                </StackPanel>
                                <Grid ColumnDefinitions="*, Auto">
                                    <ComboBox
                                        DisplayMemberBinding="{Binding}"
                                        Grid.Column="0"
                                        HorizontalAlignment="Stretch"
                                        IsEnabled="{Binding !IsEmpty}"
                                        ItemsSource="{Binding ShortenerUploaders}"
                                        SelectedItem="{Binding SelectedShortenerUploader}" />
                                    <Button
                                        Command="{Binding TestUploaderCommand}"
                                        CommandParameter="{Binding SelectedShortenerUploader}"
                                        Content="Test"
                                        FontSize="11"
                                        Grid.Column="1"
                                        IsEnabled="{Binding !IsEmpty}"
                                        Margin="4,0,0,0"
                                        VerticalAlignment="Stretch" />
                                </Grid>
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <avalonia:SymbolIcon FontSize="18" Symbol="ShareMultiple" />

                                    <TextBlock
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Text="Sharing" />
                                </StackPanel>
                                <Grid ColumnDefinitions="*, Auto">
                                    <ComboBox
                                        DisplayMemberBinding="{Binding}"
                                        Grid.Column="0"
                                        HorizontalAlignment="Stretch"
                                        IsEnabled="{Binding !IsEmpty}"
                                        ItemsSource="{Binding SharingUploaders}"
                                        SelectedItem="{Binding SelectedSharingUploader}" />
                                    <Button
                                        Command="{Binding TestUploaderCommand}"
                                        CommandParameter="{Binding SelectedSharingUploader}"
                                        Content="Test"
                                        FontSize="11"
                                        Grid.Column="1"
                                        IsEnabled="{Binding !IsEmpty}"
                                        Margin="4,0,0,0"
                                        VerticalAlignment="Stretch" />
                                </Grid>
                            </StackPanel>

                        </StackPanel>
                    </StackPanel>
                </Border>
                <ScrollViewer DockPanel.Dock="Top">
                    <StackPanel>
                        <DockPanel LastChildFill="False" Margin="8">
                            <Button
                                Command="{Binding AddUploaderCommand}"
                                CornerRadius="8"
                                DockPanel.Dock="Right"
                                Padding="4">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <avalonia:SymbolIcon FontSize="18" Symbol="AddSquare" />
                                </StackPanel>
                            </Button>
                            <Button
                                Command="{Binding ImportUploaderCommand}"
                                CornerRadius="8"
                                DockPanel.Dock="Right"
                                Margin="0,0,8,0"
                                Padding="4">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <avalonia:SymbolIcon FontSize="18" Symbol="ArrowImport" />
                                    <TextBlock
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Text="Import"
                                        VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button
                                Command="{Binding OpenCatalogCommand}"
                                CornerRadius="8"
                                DockPanel.Dock="Right"
                                Margin="0,0,8,0"
                                Padding="8,4">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <avalonia:SymbolIcon FontSize="18" Symbol="Library" />
                                    <TextBlock
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Text="Catalog"
                                        VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </DockPanel>

                        <ListBox ItemsSource="{Binding Uploaders}" SelectedItem="{Binding SelectedUploader, Mode=TwoWay}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock
                                            TextTrimming="CharacterEllipsis"
                                            VerticalAlignment="Center"
                                            Width="150">
                                            <TextBlock.Text>
                                                <MultiBinding Converter="{StaticResource CustomUploaderNameConverter}">
                                                    <Binding Path="Name" />
                                                    <Binding Path="RequestURL" />
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </SplitView.Pane>

        <!--  Editor  -->
        <SplitView.Content>
            <Grid>
                <ContentControl Content="{Binding SelectedUploader, Mode=TwoWay}" IsVisible="{Binding !IsEmpty}">
                    <ContentControl.ContentTemplate>
                        <DataTemplate DataType="{x:Type upload:CustomUploaderItem}">
                            <ScrollViewer>
                                <StackPanel Margin="16" Spacing="12">

                                    <!--  Name + URL  -->
                                    <StackPanel Margin="0,5" Spacing="10">
                                        <TextBox
                                            CornerRadius="4"
                                            Height="32"
                                            HorizontalAlignment="Left"
                                            Text="{Binding Name, Mode=TwoWay}"
                                            VerticalContentAlignment="Center"
                                            Watermark="{Binding $parent[UserControl].((viewModels:CustomUploaderVM)DataContext).DynamicWatermark}"
                                            Width="350" />

                                        <TextBox
                                            CornerRadius="4"
                                            Text="{Binding RequestURL, Mode=TwoWay}"
                                            VerticalContentAlignment="Center"
                                            Watermark="https://example.com/upload" />

                                        <Separator
                                            Height="1"
                                            Margin="0,5"
                                            Opacity="0.5" />
                                    </StackPanel>

                                    <Grid
                                        ColumnDefinitions="Auto, Auto, Auto, *"
                                        Margin="0,10"
                                        RowDefinitions="*, *">
                                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                            <Label
                                                Content="HTTP Method"
                                                FontWeight="SemiBold"
                                                Padding="0,0,0,4" />
                                            <controls:FAComboBox
                                                HorizontalAlignment="Stretch"
                                                ItemsSource="{Binding $parent[UserControl].((viewModels:CustomUploaderVM)DataContext).AllHttpMethods}"
                                                SelectedItem="{Binding RequestMethod, Mode=TwoWay}" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                            <Label
                                                Content="Body"
                                                FontWeight="SemiBold"
                                                Padding="0,0,0,4" />
                                            <controls:FAComboBox
                                                HorizontalAlignment="Stretch"
                                                ItemsSource="{Binding $parent[UserControl].((viewModels:CustomUploaderVM)DataContext).AllBodyTypes}"
                                                SelectedItem="{Binding Body, Mode=TwoWay}" />
                                        </StackPanel>
                                        <StackPanel
                                            Grid.Column="2"
                                            Margin="8,0,0,0"
                                            Width="265">
                                            <Label Content="Destination Type" FontWeight="SemiBold" />
                                            <DropDownButton Content="{Binding DestinationType}" HorizontalAlignment="Stretch">
                                                <DropDownButton.Flyout>
                                                    <Flyout>
                                                        <ItemsControl ItemsSource="{Binding $parent[UserControl].((viewModels:CustomUploaderVM)DataContext).AllDestinationTypes}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <CheckBox
                                                                        Command="{Binding $parent[UserControl].((viewModels:CustomUploaderVM)DataContext).ToggleDestinationTypeCommand}"
                                                                        CommandParameter="{Binding}"
                                                                        Content="{Binding}">
                                                                        <CheckBox.IsChecked>
                                                                            <MultiBinding Converter="{StaticResource EnumToBool}" Mode="OneWay">
                                                                                <Binding Path="$parent[UserControl].((viewModels:CustomUploaderVM)DataContext).SelectedUploader.DestinationType" />
                                                                                <Binding />
                                                                            </MultiBinding>
                                                                        </CheckBox.IsChecked>
                                                                    </CheckBox>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </Flyout>
                                                </DropDownButton.Flyout>
                                            </DropDownButton>
                                        </StackPanel>
                                    </Grid>
                                    <!--  Headers  -->
                                    <StackPanel Margin="0,5" Spacing="4">

                                        <StackPanel
                                            Margin="0,5,0,0"
                                            Orientation="Horizontal"
                                            Spacing="6">
                                            <TextBlock
                                                FontSize="12"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource SystemAccentColor}"
                                                LetterSpacing="1.2"
                                                Text="HEADERS"
                                                VerticalAlignment="Center" />
                                            <Button
                                                Classes="Hyperlink"
                                                Command="{Binding $parent[UserControl].((viewModels:CustomUploaderVM)DataContext).OpenUrlCommand}"
                                                CommandParameter="https://getsharex.com/docs/custom-uploader#headers"
                                                Padding="0"
                                                VerticalAlignment="Center">
                                                <avalonia:FluentIcon
                                                    Cursor="Hand"
                                                    FontSize="14"
                                                    Icon="QuestionCircle"
                                                    Opacity="0.6">
                                                    <ToolTip.Tip>
                                                        <TextBlock xml:space="preserve">• Purpose: Headers send "hidden" background info with your request, usually for security or telling the site what kind of data you're sending.
• Overriding: You can customize standard settings like your "User-Agent" (what browser the site thinks you're using) or "Cookies."
• Authentication: This is the most common use. It proves who you are so the site allows the upload.

Examples:
• Login: Authorization = Basic {base64:user:pass}
• API Key: api_key = eUM14R4g4pMs

Need more info? Click me and I'll open the documentation.</TextBlock>
                                                    </ToolTip.Tip>
                                                </avalonia:FluentIcon>
                                            </Button>
                                        </StackPanel>
                                        <Border
                                            Background="{DynamicResource SystemAccentColor}"
                                            Height="1"
                                            HorizontalAlignment="Stretch"
                                            Opacity="0.4" />
                                    </StackPanel>
                                    <ItemsControl ItemsSource="{Binding Headers}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel
                                                    Margin="4"
                                                    Orientation="Horizontal"
                                                    Spacing="8">
                                                    <TextBox Text="{Binding Key, Mode=TwoWay}" Width="120" />
                                                    <TextBox
                                                        Classes="revealable"
                                                        PointerEntered="OnPointerEntered"
                                                        PointerExited="OnPointerExited"
                                                        Text="{Binding Value, Mode=TwoWay}"
                                                        Width="180">
                                                        <TextBox.Effect>
                                                            <BlurEffect Radius="{Binding Key, Converter={StaticResource HeaderSecurityBlurConverter}}" />
                                                        </TextBox.Effect>
                                                    </TextBox>
                                                    <Button
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Command="{Binding $parent[UserControl].((viewModels:CustomUploaderVM)DataContext).RemoveHeaderCommand}"
                                                        CommandParameter="{Binding}"
                                                        Content="❌"
                                                        Foreground="Red" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <Button Command="{Binding $parent[UserControl].((viewModels:CustomUploaderVM)DataContext).AddHeaderCommand}" Content="Add Header" />

                                    <!--  Parameters  -->
                                    <StackPanel Margin="0,5" Spacing="4">
                                        <StackPanel
                                            Margin="0,5,0,0"
                                            Orientation="Horizontal"
                                            Spacing="6">
                                            <TextBlock
                                                FontSize="12"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource SystemAccentColor}"
                                                LetterSpacing="1.2"
                                                Text="PARAMETERS"
                                                VerticalAlignment="Center" />
                                            <Button
                                                Classes="Hyperlink"
                                                Command="{Binding $parent[UserControl].((viewModels:CustomUploaderVM)DataContext).OpenUrlCommand}"
                                                CommandParameter="https://getsharex.com/docs/custom-uploader#url-parameters"
                                                Padding="0"
                                                VerticalAlignment="Center">
                                                <avalonia:FluentIcon
                                                    Cursor="Hand"
                                                    FontSize="14"
                                                    Icon="QuestionCircle"
                                                    Opacity="0.6">
                                                    <ToolTip.Tip>
                                                        <TextBlock xml:space="preserve">• Parameters: These create a URL "query string" (the text after the '?' in a link) to send settings to a website.
• Placeholders: Use {input} to automatically insert the text or URL you are currently uploading.
• Shortcuts: Use shortcuts like %mo to automatically insert the current month.

Example:
If you set: api_key = eUM14R4g4pMs and private = true
The resulting link looks like:
https://example.com/upload.php?api_key=eUM14R4g4pMs&amp;private=true

Need more info? Click me and I'll open the documentation.</TextBlock>
                                                    </ToolTip.Tip>
                                                </avalonia:FluentIcon>
                                            </Button>
                                        </StackPanel>
                                        <Border
                                            Background="{DynamicResource SystemAccentColor}"
                                            Height="1"
                                            HorizontalAlignment="Stretch"
                                            Opacity="0.4" />
                                    </StackPanel>
                                    <ItemsControl ItemsSource="{Binding Parameters}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel
                                                    Margin="4"
                                                    Orientation="Horizontal"
                                                    Spacing="8">
                                                    <TextBox Text="{Binding Key, Mode=TwoWay}" Width="120" />
                                                    <TextBox
                                                        Classes="revealable"
                                                        PointerEntered="OnPointerEntered"
                                                        PointerExited="OnPointerExited"
                                                        Text="{Binding Value, Mode=TwoWay}"
                                                        Width="180">
                                                        <TextBox.Effect>
                                                            <BlurEffect Radius="{Binding Key, Converter={StaticResource HeaderSecurityBlurConverter}}" />
                                                        </TextBox.Effect>
                                                    </TextBox>
                                                    <Button
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Command="{Binding $parent[UserControl].((viewModels:CustomUploaderVM)DataContext).RemoveParameterCommand}"
                                                        CommandParameter="{Binding}"
                                                        Content="❌"
                                                        Foreground="Red" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <Button
                                        Command="{Binding $parent[UserControl].((viewModels:CustomUploaderVM)DataContext).AddParameterCommand}"
                                        CommandParameter="{Binding}"
                                        Content="Add Parameter" />
                                    <!--  Arguments  -->
                                    <StackPanel Margin="0,5" Spacing="4">

                                        <StackPanel
                                            Margin="0,5,0,0"
                                            Orientation="Horizontal"
                                            Spacing="6">
                                            <TextBlock
                                                FontSize="12"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource SystemAccentColor}"
                                                LetterSpacing="1.2"
                                                Text="ARGUMENTS"
                                                VerticalAlignment="Center" />
                                            <Button
                                                Classes="Hyperlink"
                                                Command="{Binding $parent[UserControl].((viewModels:CustomUploaderVM)DataContext).OpenUrlCommand}"
                                                CommandParameter="https://getsharex.com/docs/custom-uploader#body-arguments"
                                                Padding="0"
                                                VerticalAlignment="Center">
                                                <avalonia:FluentIcon
                                                    Cursor="Hand"
                                                    FontSize="14"
                                                    Icon="QuestionCircle"
                                                    Opacity="0.6">
                                                    <ToolTip.Tip>
                                                        <TextBlock xml:space="preserve">• Purpose: For text uploaders or link shorteners, this is the actual "payload" (the specific content you are sending).
• Automatic Filling: Use the {input} placeholder to tell the app exactly where to drop your copied text or link inside the request.

Example:
If you set: text = {input}
The app swaps "{input}" for whatever text you are currently trying to upload.

Need more info? Click me and I'll open the documentation.</TextBlock>
                                                    </ToolTip.Tip>
                                                </avalonia:FluentIcon>
                                            </Button>
                                        </StackPanel>
                                        <Border
                                            Background="{DynamicResource SystemAccentColor}"
                                            Height="1"
                                            HorizontalAlignment="Stretch"
                                            Opacity="0.4" />
                                    </StackPanel>
                                    <ItemsControl ItemsSource="{Binding Arguments}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel
                                                    Margin="4"
                                                    Orientation="Horizontal"
                                                    Spacing="8">
                                                    <TextBox Text="{Binding Key, Mode=TwoWay}" Width="120" />
                                                    <TextBox
                                                        Classes="revealable"
                                                        PointerEntered="OnPointerEntered"
                                                        PointerExited="OnPointerExited"
                                                        Text="{Binding Value, Mode=TwoWay}"
                                                        Width="180">
                                                        <TextBox.Effect>
                                                            <BlurEffect Radius="{Binding Key, Converter={StaticResource HeaderSecurityBlurConverter}}" />
                                                        </TextBox.Effect>
                                                    </TextBox>
                                                    <Button
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Command="{Binding $parent[UserControl].((viewModels:CustomUploaderVM)DataContext).RemoveArgumentCommand}"
                                                        CommandParameter="{Binding}"
                                                        Content="❌"
                                                        Foreground="Red" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <Button
                                        Command="{Binding $parent[UserControl].((viewModels:CustomUploaderVM)DataContext).AddArgumentCommand}"
                                        CommandParameter="{Binding}"
                                        Content="Add Argument" />
                                    <StackPanel Grid.Column="0" Grid.Row="1">
                                        <Label Content="File Form Name" FontWeight="SemiBold" />
                                        <TextBox
                                            CornerRadius="4"
                                            Height="24"
                                            HorizontalAlignment="Left"
                                            Text="{Binding FileFormName, Mode=TwoWay}"
                                            VerticalContentAlignment="Center"
                                            Watermark="file"
                                            Width="100" />
                                    </StackPanel>
                                    <StackPanel>
                                        <Label Content="URL" FontWeight="SemiBold" />
                                        <TextBox
                                            CornerRadius="4"
                                            Height="24"
                                            HorizontalAlignment="Left"
                                            Text="{Binding URL, Mode=TwoWay}"
                                            VerticalContentAlignment="Center"
                                            Watermark="{}{json:url}"
                                            Width="450">
                                            <ToolTip.Tip>
                                                <views:UploaderToolTips />
                                            </ToolTip.Tip>
                                        </TextBox>
                                    </StackPanel>
                                    <StackPanel>
                                        <Label Content="Thumbnail URL" FontWeight="SemiBold" />
                                        <TextBox
                                            CornerRadius="4"
                                            Height="24"
                                            HorizontalAlignment="Left"
                                            Text="{Binding ThumbnailURL, Mode=TwoWay}"
                                            VerticalContentAlignment="Center"
                                            Watermark="{}{json:thumbnail_url}"
                                            Width="450">
                                            <ToolTip.Tip>
                                                <views:UploaderToolTips />
                                            </ToolTip.Tip>
                                        </TextBox>
                                    </StackPanel>
                                    <StackPanel>
                                        <Label Content="Deletion URL" FontWeight="SemiBold" />
                                        <TextBox
                                            CornerRadius="4"
                                            Height="24"
                                            HorizontalAlignment="Left"
                                            Text="{Binding DeletionURL, Mode=TwoWay}"
                                            VerticalContentAlignment="Center"
                                            Watermark="{}{json:deletion_url}"
                                            Width="450">
                                            <ToolTip.Tip>
                                                <views:UploaderToolTips />
                                            </ToolTip.Tip>
                                        </TextBox>
                                    </StackPanel>
                                    <StackPanel>
                                        <Label Content="Error Message Path" FontWeight="SemiBold" />
                                        <TextBox
                                            CornerRadius="4"
                                            Height="24"
                                            HorizontalAlignment="Left"
                                            Text="{Binding ErrorMessage, Mode=TwoWay}"
                                            VerticalContentAlignment="Center"
                                            Watermark="{}{json:error}"
                                            Width="450">
                                            <ToolTip.Tip>
                                                <views:UploaderToolTips />
                                            </ToolTip.Tip>
                                        </TextBox>
                                    </StackPanel>
                                    <StackPanel Spacing="5">
                                        <TextBlock
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            Text="Data" />
                                        <TextBox
                                            AcceptsReturn="True"
                                            AcceptsTab="True"
                                            FontFamily="Cascadia Code, Consolas, Monospace"
                                            Height="200"
                                            Text="{Binding Data}"
                                            TextWrapping="Wrap"
                                            ToolTip.Tip="Payload which can be JSON, XML, plain text, etc                       You can use {input} or {filename} as variables."
                                            VerticalContentAlignment="Top" />
                                    </StackPanel>
                                    <DockPanel LastChildFill="False" Margin="8">
                                        <StackPanel
                                            DockPanel.Dock="Right"
                                            Orientation="Horizontal"
                                            Spacing="8">
                                            <Button
                                                Command="{Binding $parent[UserControl].((viewModels:CustomUploaderVM)DataContext).DuplicateUploaderCommand}"
                                                CommandParameter="{Binding}"
                                                Content="Duplicate" />
                                            <Button
                                                Command="{Binding $parent[UserControl].((viewModels:CustomUploaderVM)DataContext).TestUploaderCommand}"
                                                CommandParameter="{Binding}"
                                                Content="Test" />
                                            <Button
                                                Command="{Binding $parent[UserControl].((viewModels:CustomUploaderVM)DataContext).ExportUploaderCommand}"
                                                CommandParameter="{Binding}"
                                                Content="Export" />
                                            <Button
                                                Command="{Binding $parent[UserControl].((viewModels:CustomUploaderVM)DataContext).RemoveUploaderCommand}"
                                                CommandParameter="{Binding}"
                                                Content="Remove" />
                                        </StackPanel>
                                    </DockPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>
                <StackPanel
                    HorizontalAlignment="Center"
                    IsVisible="{Binding IsEmpty}"
                    Spacing="10"
                    VerticalAlignment="Center">

                    <TextBlock
                        FontSize="18"
                        FontWeight="SemiBold"
                        HorizontalAlignment="Center"
                        Text="Wow, a fresh start!" />

                    <TextBlock
                        MaxWidth="300"
                        Opacity="0.7"
                        Text="Open the catalog to import a pre-made configuration with no hassle!"
                        TextAlignment="Center"
                        TextWrapping="Wrap" />

                    <Button
                        Classes="accent"
                        Command="{Binding OpenCatalogCommand}"
                        Content="Open Catalog"
                        HorizontalAlignment="Center"
                        Margin="0,10,0,0" />
                </StackPanel>
            </Grid>
        </SplitView.Content>
    </SplitView>
</UserControl>
