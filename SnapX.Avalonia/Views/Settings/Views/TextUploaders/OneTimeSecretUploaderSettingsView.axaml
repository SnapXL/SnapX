<UserControl
    x:Class="SnapX.Avalonia.Views.Settings.Views.TextUploaders.OneTimeSecretUploadSettingsView"
    x:DataType="txt:OneTimeSecret"
    xmlns="https://github.com/avaloniaui"
    xmlns:controls="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
    xmlns:txt="clr-namespace:SnapX.Core.Upload.Text;assembly=SnapX.Core"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Spacing="4">
        <controls:SettingsExpanderItem Content="Email" Description="Might also work with Username, that is untested though">
            <controls:SettingsExpanderItem.Footer>
                <TextBox
                    Name="txtEmail"
                    Watermark="test.email@example.com"
                    Width="200" />
            </controls:SettingsExpanderItem.Footer>
        </controls:SettingsExpanderItem>

        <controls:SettingsExpanderItem Content="API Key">
            <controls:SettingsExpanderItem.Footer>
                <TextBox
                    Name="txtAPIKey"
                    PasswordChar="*"
                    Width="200" />
            </controls:SettingsExpanderItem.Footer>
        </controls:SettingsExpanderItem>
    </StackPanel>
</UserControl>
