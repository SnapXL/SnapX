<windowing:AppWindow
    Title="QR Code"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="SnapX.Avalonia.Views.QRCodeView"
    xmlns="https://github.com/avaloniaui"
    xmlns:controls="clr-namespace:SnapX.Avalonia.Views.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:miscellaneous="clr-namespace:SnapX.Core.Utils.Miscellaneous;assembly=SnapX.Core"
    xmlns:windowing="clr-namespace:FluentAvalonia.UI.Windowing;assembly=FluentAvalonia"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel>
        <StackPanel Margin="10" Spacing="8">
            <Label>Text:</Label>
            <TextBox
                AcceptsReturn="True"
                Height="650"
                Name="QRText"
                Text="{x:Static miscellaneous:Links.GitHub}"
                TextChanged="TextBox_OnTextChanged"
                TextWrapping="Wrap"
                Width="800" />
        </StackPanel>
        <StackPanel
            DockPanel.Dock="Bottom"
            HorizontalAlignment="Right"
            Margin="10"
            Orientation="Vertical"
            Spacing="8"
            VerticalAlignment="Center">
            <StackPanel
                Orientation="Horizontal"
                Spacing="4"
                VerticalAlignment="Center">
                <Label>QR code size:</Label>
                <NumericUpDown
                    FormatString="F0"
                    MaxWidth="300"
                    Maximum="200000"
                    Minimum="64"
                    Name="QRSize"
                    Value="64"
                    ValueChanged="NumericUpDown_OnValueChanged" />
                <TextBlock
                    Text="px"
                    TextTrimming="WordEllipsis"
                    TextWrapping="Wrap"
                    VerticalAlignment="Center" />
            </StackPanel>
            <Border
                Background="White"
                Height="550"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Width="550">
                <controls:SmartImage
                    HorizontalAlignment="Center"
                    Name="QRImage"
                    Stretch="Uniform"
                    VerticalAlignment="Center" />
            </Border>
            <StackPanel
                HorizontalAlignment="Center"
                Margin="10"
                Orientation="Horizontal"
                Spacing="8"
                VerticalAlignment="Center">

                <Button Click="CopyImageButtonPressed" Width="170">Copy image</Button>
                <Button Click="SaveImageButtonPressed" Width="170">Save image</Button>
                <Button Click="UploadImageButtonPressed" Width="170">Upload image</Button>
            </StackPanel>
        </StackPanel>

    </DockPanel>
</windowing:AppWindow>

