{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"extends": ["config:recommended", ":semanticCommitTypeAll(build)"],
	"prCreation": "not-pending",
	"semanticCommits": "enabled",
	"automerge": true,
	"labels": ["dependencies"],
	"automergeSchedule": ["after 10pm every weekday", "before 5am every weekday", "every weekend"],
	"prConcurrentLimit": 0,
	"prHourlyLimit": 0,
	"branchConcurrentLimit": 20,
	"branchPrefix": "dep/",
	"branchPrefixOld": "renovate/",
    "minimumReleaseAge": "8 hours",
    "timezone": "America/New_York",
    "packageRules": [
          {
            "matchDepTypes": ["action"],
            "labels": ["actions"],
            "minimumReleaseAge": "2 days"
          },
          {
            "matchDepNames": [".*[Dd]otnet.*", "Microsoft.Extensions*", "Microsoft.Data*"],
            "minimumReleaseAge": "4 days"
          },
          {
            "description": "Merge Brycen's amazing packages soon as possible",
            "matchDepNames": ["*BrycensRanch*", "WaylandSharper"],
            "minimumReleaseAge": "0 minutes"
          },
          {
            "matchDepNames": ["*Wayland*", "*DBus*"],
            "labels": ["linux"]
          },
          {
            "matchDepNames": ["xcap", "*osx*"],
            "labels": ["macOS"],
            "minimumReleaseAge": "7 days"
          },
          {
            "matchDepNames": [".*[Ww]indows.*", "*Vortice*", "*PowerShell*", "*Win32*", "*runtime.win*", "*win64*"],
            "labels": ["windows"]
          }
      ]
}
